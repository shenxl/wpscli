# WPS CLI local environment configuration
# Copy to .env and fill with your own values.

# App credentials (AK/SK)
WPS_CLI_AK=your_app_ak_here
WPS_CLI_SK=your_app_sk_here

# Optional: OAuth user-login config (if different from AK/SK)
# WPS_CLI_OAUTH_CLIENT_ID=your_oauth_client_id
# WPS_CLI_OAUTH_CLIENT_SECRET=your_oauth_client_secret
# WPS_CLI_OAUTH_REDIRECT_URI=http://localhost:53682/callback
# WPS_CLI_OAUTH_SCOPE=kso.user_base.read

# Optional: direct access token override (highest priority)
# WPS_CLI_TOKEN=your_access_token_here

# Optional: use external oauth server for token fetch
# WPS_OAUTH_SERVER=http://localhost:8089

# Optional: override config directory
# WPS_CLI_CONFIG_DIR=~/.config/wps
