          {
            "name": "allotee_type",
            "location": "query",
            "ptype": "string",
            "required": true,
            "description": "盘归属身份类型，盘归属身份类型：user-获取操作者自己的私有盘列表，group-获取用户组下的盘列表, app-获取应用下的应用盘列表",
