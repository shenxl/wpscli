      "id": "batch-get-file-info",
      "doc_id": 514,
      "name": "批量获取文件信息",
      "summary": "批量获取文件信息",
      "http_method": "GET",
      "path": "/v7/files/batch_get",
      "signature": "KSO-1",
      "scopes": [
        "kso.file.readwrite",
        "kso.file.read",
        "kso.file.readwrite",
        "kso.file.read"
      ],
      "params": {
        "path": [],
        "query": [
          {
            "name": "file_ids",
            "location": "query",
            "ptype": "array",
            "required": true,
            "description": "文件ID列表",
            "enum": null
          },
          {
            "name": "with_permission",
            "location": "query",
            "ptype": "boolean",
            "required": false,
            "description": "是否返回文件操作权限",
            "enum": null
          },
          {
            "name": "with_ext_attrs",
            "location": "query",
            "ptype": "boolean",
            "required": false,
            "description": "是否返回文件扩展属性",
            "enum": null
          },
          {
            "name": "with_drive",
            "location": "query",
            "ptype": "boolean",
            "required": false,
            "description": "是否返回文件所属drive信息",
            "enum": null
          },
          {
            "name": "mode",
            "location": "query",
            "ptype": "string",
            "required": false,
            "description": "批量获取结果的返回模式。（默认）fastfail-快速失败，遇到错误时立即终止并返回；detailed-返回详情，遇到错误时继续执行，最终返回成功的文件集合和失败列表。",
            "enum": [
              "`fastfail`",
              "`detailed`"
            ]
          }
        ],
        "header": []
      }
