        "kso.subscription_account.read"
      ],
      "params": {
        "path": [
          {
            "name": "account_id",
            "location": "path",
            "ptype": "string",
            "required": true,
            "description": "账号ID，，由【获取订阅号账号列表】接口id字段返回",
            "enum": null
          },
          {
            "name": "store_key",
            "location": "path",
            "ptype": "string",
            "required": true,
            "description": "文件store_key，由账号相关接口中涉及文件资源的字段返回",
            "enum": null
          }
        ],
        "query": [],
        "header": []
      }
    },
    {
      "id": "get-subscription-accounts",
