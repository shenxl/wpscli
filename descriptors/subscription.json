        "kso.subscription_account.read"
      ],
      "params": {
        "path": [],
        "query": [
          {
            "name": "page_size",
            "location": "query",
            "ptype": "integer",
            "required": false,
            "description": "每页大小，最大为100，默认为20",
            "enum": null
          },
          {
            "name": "page_token",
            "location": "query",
            "ptype": "string",
            "required": false,
            "description": "分页token，首页传空串",
            "enum": null
          }
        ],
        "header": [
          {
            "name": "X-Kso-Id-Type",
            "location": "header",
            "ptype": "string",
            "required": false,
            "description": "类型  * **internal** - 内部  * **external** - 外部",
            "enum": [
              "`internal`",
              "`external`"
            ]
          }
        ]
      }
    },
    {
